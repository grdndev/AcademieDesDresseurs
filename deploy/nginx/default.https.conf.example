# TLS-ready Nginx config template for OVH
# 1) Replace domain names if needed.
# 2) Ensure cert files exist (Let's Encrypt or OVH-managed certificates).
# 3) Mount cert path in docker-compose.proxy.yml.

server {
    listen 80;
    server_name academiedesdresseurs.fr www.academiedesdresseurs.fr api.academiedesdresseurs.fr;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name academiedesdresseurs.fr www.academiedesdresseurs.fr;

    ssl_certificate /etc/letsencrypt/live/academiedesdresseurs.fr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/academiedesdresseurs.fr/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;

    location / {
        proxy_pass http://frontend:3000;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

server {
    listen 443 ssl http2;
    server_name api.academiedesdresseurs.fr;

    ssl_certificate /etc/letsencrypt/live/academiedesdresseurs.fr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/academiedesdresseurs.fr/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;

    location / {
        proxy_pass http://api:5001;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
