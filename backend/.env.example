# Backend runtime
NODE_ENV=production
PORT=5001

# Database
MONGO_URI=mongodb://127.0.0.1:27017/express_api_db

# Security
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
TRUST_PROXY=true

# CORS (comma-separated list of allowed origins)
# Example: https://academiedesdresseurs.fr,https://www.academiedesdresseurs.fr
CORS_ORIGINS=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Paypal (optional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
