# ── Serveur ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ── Base de données (PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://academie:academie@localhost:5432/academie_db

# ── Sécurité ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_MIN_32_CHARS
# Clé AES-256 pour chiffrement des données sensibles (IBAN, etc.)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
HMAC_SECRET=CHANGE_ME_HMAC_SECRET
TRUST_PROXY=false
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── OAuth Google ─────────────────────────────────────────────────────────────
# Récupérer sur console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Si vide → les emails sont loggués dans la console (mode dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@academiedesdresseurs.fr
APP_URL=http://localhost:3000

# ── Paiement ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
