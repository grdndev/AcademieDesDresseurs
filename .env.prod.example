# Shared image tag used by docker-compose.prod.yml
APP_TAG=latest

# Backend
DATABASE_URL=postgresql://academie:CHANGE_ME_PASSWORD@postgres:5432/academie_db
POSTGRES_USER=academie
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD
POSTGRES_DB=academie_db
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
TRUST_PROXY=true
CORS_ORIGINS=https://academiedesdresseurs.fr,https://www.academiedesdresseurs.fr

# Payment providers (optional during staging)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Frontend -> backend
NEXT_PUBLIC_API_URL=https://api.academiedesdresseurs.fr/api
NEXT_LOCAL_API_URL=http://api:5001/api

# Optional explicit image names
API_IMAGE=academiedesdresseurs/api
FRONTEND_IMAGE=academiedesdresseurs/frontend
